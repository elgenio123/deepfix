# Default to LF for cross-platform + Linux tooling.
# This avoids CRLF issues inside Docker/Linux CI.
* text=auto eol=lf

# Ensure shell scripts use LF so docker can execute them
*.sh text eol=lf

# Common source/config/docs should be LF
*.py text eol=lf
*.pyi text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.example text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.sql text eol=lf
Dockerfile* text eol=lf

# Windows-only scripts can keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
