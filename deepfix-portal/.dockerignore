*.pyc
.venv
venv
*.db

# IDE and editor files
.idea
.vscode
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Testing
coverage
.pytest_cache

# Build outputs (we want fresh builds in Docker)
dist
build
